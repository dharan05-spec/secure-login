<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>2FA Verify — SecureApp</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="page-wrapper">
  <div class="card">
    <div class="brand">
      <div class="brand-icon">🛡</div>
      <span class="brand-name">SecureApp</span>
    </div>
    <h1>Enter your code</h1>
    <p class="subtitle">Open your authenticator app and enter the 6-digit code.</p>

    <% if (errors.length) { %>
      <ul class="errors-box">
        <% errors.forEach(e => { %><li>⚠ <%= e.msg %></li><% }) %>
      </ul>
    <% } %>

    <form method="POST" action="/2fa/verify">
      <div class="form-group">
        <label for="token">6-digit code</label>
        <input type="number" id="token" name="token" class="otp-input" placeholder="000000" maxlength="6" required />
      </div>
      <button type="submit" class="btn btn-primary">Verify →</button>
    </form>
    <div class="link-row"><a href="/login">← Back to Login</a></div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
